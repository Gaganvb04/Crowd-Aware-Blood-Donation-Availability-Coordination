# BloodConnect Backend Configuration
# IMPORTANT: Copy this file to .env and update with your actual values

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-change-this-in-production-12345
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production-67890

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Face@123
DB_NAME=bloodconnect

# MySQL Connection String (Alternative - use this format)
DATABASE_URL=mysql+pymysql://root:your_mysql_password_here@localhost:3306/bloodconnect

# CORS Configuration (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5000,http://127.0.0.1:5000

# JWT Configuration (in seconds)
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# File Upload Configuration
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# Application Settings
PAGINATION_PER_PAGE=20
MINIMUM_STOCK_THRESHOLD=20
CRITICAL_STOCK_THRESHOLD=10
EXPIRY_WARNING_DAYS=7

# Logging
LOG_LEVEL=DEBUG
LOG_FILE=logs/app.log

# Optional: Email Configuration (for future use)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password

# Optional: SMS Configuration (for future use)
# SMS_API_KEY=your-sms-api-key
# SMS_SENDER_ID=BloodConnect

# Optional: Redis Configuration (for caching)
# REDIS_URL=redis://localhost:6379/0